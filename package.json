{
  "name": "madrasah-revision",
  "private": true,
  "version": "0.1.0",
  "description": "Madrasah revision platform \u2014 Tas-heel series. Admin creates teachers; teachers have one class of students. Vite + React frontend, Express + PostgreSQL backend.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "db:up": "docker compose up -d",
    "db:schema": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:seed": "npm --workspace backend run seed",
    "build": "npm --workspace frontend run build",
    "scaffold": "node scripts/scaffold.mjs"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}